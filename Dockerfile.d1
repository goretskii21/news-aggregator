FROM alpine:3.20

RUN apk add --no-cache sqlite

WORKDIR /app

COPY db/schema.sql /app/schema.sql
COPY db/local-d1-entrypoint.sh /usr/local/bin/local-d1-entrypoint

RUN chmod +x /usr/local/bin/local-d1-entrypoint

ENV D1_DB_PATH=/data/news-aggr-d1.sqlite

VOLUME ["/data"]

ENTRYPOINT ["local-d1-entrypoint"]
